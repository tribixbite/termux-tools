{
  "name": "drey",
  "version": "0.1.0",
  "type": "commonjs",
  "description": "Session orchestrator for Claude Code — manages tmux sessions, health checks, auto-restart, and a web dashboard. A drey is a squirrel's nest — home base for your AI workforce.",
  "author": "tribixbite",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tribixbite/termux-tools",
    "directory": "orchestrator"
  },
  "bin": {
    "drey": "dist/tmx.js"
  },
  "files": [
    "dist/",
    "dashboard/dist/",
    "watchdog.sh"
  ],
  "keywords": [
    "claude",
    "tmux",
    "orchestrator",
    "session-manager",
    "claude-code",
    "terminal"
  ],
  "scripts": {
    "build": "node build.cjs",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/fix-android-binaries.mjs"
  },
  "devDependencies": {
    "@esbuild/android-arm64": "^0.24.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "claude-chrome-android": "*"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  }
}
