---
import Layout from "../layouts/Layout.astro";
import SessionTable from "../components/SessionTable.svelte";
import MemoryGauge from "../components/MemoryGauge.svelte";
import BudgetGauge from "../components/BudgetGauge.svelte";
import BridgeStatus from "../components/BridgeStatus.svelte";
import AdbStatus from "../components/AdbStatus.svelte";
import ServiceStatus from "../components/ServiceStatus.svelte";
import TokenSummary from "../components/TokenSummary.svelte";
import RecentSessions from "../components/RecentSessions.svelte";
import PromptLibrary from "../components/PromptLibrary.svelte";
---

<Layout title="operad dashboard" active="overview">
  <!-- Compact status cards -->
  <div class="status-strip">
    <MemoryGauge client:load />
    <BudgetGauge client:load />
    <TokenSummary client:load />
    <BridgeStatus client:load />
    <AdbStatus client:load />
    <ServiceStatus client:load />
  </div>

  <!-- Session table -->
  <div class="card mb-4">
    <h2 class="text-xs font-medium text-[var(--text-secondary)] uppercase tracking-wide mb-3">Sessions</h2>
    <SessionTable client:load />
  </div>

  <!-- Prompt library -->
  <PromptLibrary client:load />

  <!-- Recent projects from history -->
  <RecentSessions client:load />
</Layout>

<style>
  .status-strip {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-bottom: 0.75rem;
  }
</style>
