---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const categories = [
  {
    title: "Getting Started",
    color: "text-terminal-green",
    docs: [
      { name: "SUMMARY.md", title: "Project Summary", desc: "Overview of all termux-tools components" },
      { name: "ARCHITECTURE.md", title: "Architecture Overview", desc: "System design and component relationships" },
      { name: "QUICK_REFERENCE.md", title: "Quick Reference", desc: "Tmux aliases and keyboard shortcuts" },
      { name: "WORKFLOWS.md", title: "Real-World Workflows", desc: "Practical Claude Code workflow examples" },
    ],
  },
  {
    title: "Boot & Startup",
    color: "text-terminal-cyan",
    docs: [
      { name: "BOOT_ARCHITECTURE.md", title: "Boot Architecture", desc: "How the boot sequence works internally" },
      { name: "TERMUX_BOOT_QUICKSTART.md", title: "Boot Quick Start", desc: "Get up and running with Termux:Boot" },
      { name: "TERMUX_BOOT_SETUP.md", title: "Boot Setup Guide", desc: "Detailed Termux:Boot configuration" },
      { name: "CRONTAB_AUTOMATION.md", title: "Crontab Automation", desc: "Scheduled tasks and cron setup" },
    ],
  },
  {
    title: "Commands",
    color: "text-terminal-amber",
    docs: [
      { name: "TM_COMMAND.md", title: "tm — Smart Window Switcher", desc: "Switch between tmux sessions with fuzzy matching" },
      { name: "TMGO_COMMAND.md", title: "tmgo — Send 'go' Remotely", desc: "Resume Claude Code sessions without switching" },
      { name: "TMUX_ALIASES_GUIDE.md", title: "Tmux Aliases Guide", desc: "All shell aliases for session management" },
    ],
  },
  {
    title: "ADB & Tasker",
    color: "text-terminal-cyan",
    docs: [
      { name: "ADB_WIRELESS_GUIDE.md", title: "ADB Wireless Automation", desc: "Auto-connect ADB over WiFi" },
      { name: "TASKER_ADB_SETUP.md", title: "Tasker via ADB", desc: "Configure Tasker automation through ADB" },
      { name: "TASKER_SETUP.md", title: "Tasker Automation Setup", desc: "Full Tasker integration guide" },
    ],
  },
  {
    title: "Claude Code",
    color: "text-terminal-green",
    docs: [
      { name: "claude-code-internals-v2.1.37.md", title: "Claude Code Internals", desc: "Hidden features, codenames, and config options" },
      { name: "claude-config.md", title: "Claude Code Config Export", desc: "Configuration reference and settings" },
    ],
  },
  {
    title: "Device & System",
    color: "text-terminal-dim",
    docs: [
      { name: "camera-fix-forensic-report.md", title: "Camera Fix Report", desc: "Camera driver debugging forensics" },
      { name: "camera-ois-issue.md", title: "Camera OIS Issue", desc: "OIS driver issue — resolved" },
      { name: "stopped-packages-explained.md", title: "Stopped Packages", desc: "Why Android packages show as stopped" },
      { name: "system-disabled-packages-report.md", title: "Disabled Packages Report", desc: "System package audit" },
    ],
  },
];

const repoBase = "https://github.com/tribixbite/termux-tools/blob/main/docs";
---

<Layout
  title="Documentation — termux-tools"
  description="Guides, references, and technical docs for termux-tools: boot architecture, tmux aliases, ADB setup, Claude Code configuration, and more."
  path="docs"
>
  <Nav current="/docs" />
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden px-4 pt-16 pb-12 sm:px-6 lg:px-8">
      <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
        style="background-image: linear-gradient(var(--color-terminal-dim) 1px, transparent 1px), linear-gradient(90deg, var(--color-terminal-dim) 1px, transparent 1px); background-size: 40px 40px;">
      </div>

      <div class="relative mx-auto max-w-4xl text-center">
        <h1 class="mb-4 font-[family-name:var(--font-mono)] text-4xl font-bold tracking-tight text-terminal-bright sm:text-5xl">
          Documentation
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-terminal-dim">
          {categories.reduce((sum, c) => sum + c.docs.length, 0)} guides covering setup, commands, architecture, and debugging.
        </p>
      </div>
    </section>

    <!-- Categories -->
    {categories.map((cat) => (
      <section class="px-4 py-8 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-4 font-[family-name:var(--font-mono)] text-xl font-bold text-terminal-bright">
            <span class={cat.color}>#</span> {cat.title}
          </h2>

          <div class="grid gap-3 sm:grid-cols-2">
            {cat.docs.map((doc) => (
              <a href={`${repoBase}/${doc.name}`}
                class="group rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4 transition-colors hover:border-terminal-border hover:bg-terminal-surface"
                target="_blank" rel="noopener">
                <h3 class="mb-1 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-bright group-hover:text-terminal-cyan transition-colors">
                  {doc.title}
                </h3>
                <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
                  {doc.desc}
                </p>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}
  </main>
  <Footer />
</Layout>
