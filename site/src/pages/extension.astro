---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Claude Code Bridge Extension — termux-tools"
  description="Chrome/Edge extension that connects Claude Code to your browser tabs. Read pages, click elements, fill forms, execute JS, and monitor network requests."
  path="extension"
>
  <Nav current="/extension" />
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden px-4 pt-16 pb-20 sm:px-6 lg:px-8">
      <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
        style="background-image: linear-gradient(var(--color-terminal-amber) 1px, transparent 1px), linear-gradient(90deg, var(--color-terminal-amber) 1px, transparent 1px); background-size: 40px 40px;">
      </div>

      <div class="relative mx-auto max-w-4xl text-center">
        <div class="mb-6 inline-block rounded-lg border border-terminal-border bg-terminal-surface px-4 py-2 font-[family-name:var(--font-mono)] text-sm text-terminal-dim">
          <span class="text-terminal-amber">ext</span> claude-code-bridge <span class="text-terminal-amber">v1.7.0</span>
        </div>

        <h1 class="mb-4 font-[family-name:var(--font-mono)] text-4xl font-bold tracking-tight text-terminal-bright sm:text-5xl">
          Claude Code Bridge<span class="text-terminal-amber"> Extension</span>
        </h1>

        <p class="mx-auto mb-2 max-w-2xl text-xl text-terminal-text sm:text-2xl">
          The browser half of the bridge
        </p>

        <p class="mb-8 text-sm text-terminal-dim">
          Manifest V3 &middot; Chrome &amp; Edge &middot; WebSocket client &middot; Content script injection
        </p>

        <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="/bridge#setup"
            class="inline-flex items-center gap-2 rounded-lg border border-terminal-amber bg-terminal-amber/10 px-6 py-3 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-amber transition-colors hover:bg-terminal-amber/20">
            Install Guide
          </a>
          <a href="https://github.com/tribixbite/termux-tools/tree/main/edge-claude-ext"
            class="inline-flex items-center gap-2 rounded-lg border border-terminal-border px-6 py-3 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-text transition-colors hover:border-terminal-dim hover:text-terminal-bright"
            target="_blank" rel="noopener">
            Source
          </a>
        </div>
      </div>
    </section>

    <!-- Capabilities -->
    <section id="capabilities" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <h2 class="mb-12 text-center font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-amber">#</span> What It Can Do
        </h2>

        <div class="grid gap-6 md:grid-cols-3">
          {[
            {
              icon: "👁",
              title: "Read Pages",
              description: "Accessibility tree parsing, full text extraction, and DOM structure analysis. Works on any tab including backgrounded ones.",
              items: ["Accessibility tree", "Full page text", "Element search by text/role/aria"],
              color: "terminal-cyan",
            },
            {
              icon: "🖱",
              title: "Interact",
              description: "Click, type, scroll, fill forms, and upload files via content script injection. React/Vue-compatible event dispatch.",
              items: ["Click / type / scroll", "Form input with framework compat", "File upload"],
              color: "terminal-green",
            },
            {
              icon: "⚡",
              title: "Execute & Monitor",
              description: "Run arbitrary JavaScript, capture console output, monitor network requests, and record interactions as GIFs.",
              items: ["JavaScript execution", "Console message capture", "Network request monitoring"],
              color: "terminal-amber",
            },
          ].map((f) => (
            <div class="group rounded-lg border border-terminal-border bg-terminal-surface p-6 transition-colors hover:border-terminal-dim">
              <div class="mb-4 text-3xl">{f.icon}</div>
              <h3 class="mb-3 font-[family-name:var(--font-mono)] text-lg font-semibold text-terminal-bright">
                {f.title}
              </h3>
              <p class="mb-5 text-sm leading-relaxed text-terminal-dim">
                {f.description}
              </p>
              <div class="space-y-2">
                {f.items.map((item) => (
                  <div class="flex items-baseline gap-2 font-[family-name:var(--font-mono)] text-xs">
                    <span class={`text-${f.color}`}>›</span>
                    <span class="text-terminal-text">{item}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Extension Architecture -->
    <section id="architecture" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-amber">#</span> Architecture
        </h2>

        <div class="overflow-x-auto rounded-lg border border-terminal-border bg-terminal-surface p-6">
          <pre class="font-[family-name:var(--font-mono)] text-xs leading-relaxed sm:text-sm"><code><span class="text-terminal-dim">┌─────────────────────────────────────────────────────────┐</span>
<span class="text-terminal-dim">│</span>  <span class="text-terminal-amber">Extension (Manifest V3)</span>                                <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>                                                         <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>  <span class="text-terminal-bright">background.js</span> (service worker)                        <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>     ├── WebSocket client → <span class="text-terminal-cyan">ws://127.0.0.1:18963</span>        <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>     ├── chrome.tabs API (navigate, list, create)        <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>     ├── chrome.scripting (JS execution)                  <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>     └── 15s heartbeat / auto-reconnect                  <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>                                                         <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>  <span class="text-terminal-bright">content.js</span> (injected per-tab)                         <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>     ├── DOM interaction (click, type, scroll)            <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>     ├── Accessibility tree builder                       <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>     ├── Form input with native setter + event dispatch    <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>     └── Console interceptor (log, warn, error)           <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>                                                         <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>  <span class="text-terminal-bright">popup.html</span> (diagnostics UI)                           <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>     └── Connection status, message log (200 entries)     <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>                                                         <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">└─────────────────────────────────────────────────────────┘</span></code></pre>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-amber">Native Messaging Protocol</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
              4-byte LE length prefix + UTF-8 JSON.<br>
              Max message size: 1 MiB.
            </p>
          </div>
          <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-cyan">CDP Integration</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
              Browser-level DevTools Protocol connection.<br>
              Network monitoring, device metrics, target management.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Extension Permissions -->
    <section id="permissions" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-amber">#</span> Permissions
        </h2>

        <div class="overflow-hidden rounded-lg border border-terminal-border bg-terminal-surface">
          <table class="w-full font-[family-name:var(--font-mono)] text-xs sm:text-sm">
            <thead>
              <tr class="border-b border-terminal-border">
                <th class="px-4 py-3 text-left text-terminal-amber">Permission</th>
                <th class="px-4 py-3 text-left text-terminal-dim">Why</th>
              </tr>
            </thead>
            <tbody>
              {[
                { perm: "tabs", why: "List, navigate, and create browser tabs" },
                { perm: "scripting", why: "Execute JavaScript and inject content scripts" },
                { perm: "activeTab", why: "Access the currently active tab" },
                { perm: "nativeMessaging", why: "Communicate with the bridge process" },
                { perm: "<all_urls>", why: "Content script injection on any page" },
              ].map((p, i) => (
                <tr class={i < 4 ? "border-b border-terminal-border/30" : ""}>
                  <td class="px-4 py-2.5 text-terminal-bright">{p.perm}</td>
                  <td class="px-4 py-2.5 text-terminal-dim">{p.why}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p class="mt-4 font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
          All communication stays on localhost. No data is sent to external servers.
          See the <a href="https://github.com/tribixbite/termux-tools/blob/main/edge-claude-ext/PRIVACY.md"
          class="text-terminal-amber hover:text-terminal-bright transition-colors" target="_blank" rel="noopener">privacy policy</a>.
        </p>
      </div>
    </section>

    <!-- Known Limitations -->
    <section id="limitations" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-amber">#</span> Known Limitations
        </h2>

        <div class="space-y-4">
          {[
            {
              title: "No screenshot on Android Edge",
              desc: "captureVisibleTab is unavailable on mobile Edge. The bridge falls back to ADB screencap when ADB is connected.",
            },
            {
              title: "Service worker suspension",
              desc: "Edge may suspend the background service worker after idle. The extension auto-reconnects when woken by a new tool call.",
            },
            {
              title: "Protected pages",
              desc: "chrome://, edge://, and extension pages block content script injection. These tabs can still be listed and navigated.",
            },
            {
              title: "CRX install is manual",
              desc: "Android Edge has no programmatic extension install API. The --setup command serves the CRX and opens Edge, but you must tap \"Add extension\" manually.",
            },
          ].map((l) => (
            <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
              <h3 class="mb-1 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-bright">{l.title}</h3>
              <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">{l.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- File Structure -->
    <section id="files" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-amber">#</span> Source Files
        </h2>

        <div class="overflow-hidden rounded-lg border border-terminal-border bg-terminal-surface">
          <div class="p-4 font-[family-name:var(--font-mono)] text-sm">
            <div class="mb-2 text-terminal-dim">edge-claude-ext/</div>
            {[
              { name: "manifest.json", desc: "Manifest V3 config, permissions, service worker" },
              { name: "background.js", desc: "Service worker — WS client, tab management, tool dispatch" },
              { name: "content.js", desc: "DOM interaction, accessibility tree, form handling" },
              { name: "popup.html", desc: "Diagnostics popup — connection status, message log" },
              { name: "popup.js", desc: "Popup logic — status display, log rendering" },
              { name: "launcher.html", desc: "Bridge launch page (cfcbridge:// URL handler)" },
            ].map((d, i, arr) => (
              <div class={`flex gap-3 py-1.5 ${i < arr.length - 1 ? "border-b border-terminal-border/30" : ""}`}>
                <span class="text-terminal-dim shrink-0">{i < arr.length - 1 ? "├──" : "└──"}</span>
                <span class="text-terminal-amber shrink-0">{d.name}</span>
                <span class="text-terminal-dim text-xs leading-5">{d.desc}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
