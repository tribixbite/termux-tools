# Native libraries to remove from base.apk
# Saves ~36MB APK size, reduces mmap PSS at runtime
#
# Format: one zip entry path per line (lib/arm64-v8a/libXXX.so)
# Comments (#) and blank lines are ignored
#
# SAFE — caller already stubbed or dlopen has graceful failure path
lib/arm64-v8a/libctxlog.so
lib/arm64-v8a/liblog4cpp.so
lib/arm64-v8a/libkoom-fast-dump.so
lib/arm64-v8a/libkoom-strip-dump.so
lib/arm64-v8a/libkwai-android-base.so
lib/arm64-v8a/libtrace-canary.so
lib/arm64-v8a/liboneds.so
lib/arm64-v8a/libtelclient.so
lib/arm64-v8a/libchrome_crashpad_handler.so
lib/arm64-v8a/libcrashpad_handler_trampoline.so
lib/arm64-v8a/liblearning_tools.so
lib/arm64-v8a/libwns_push_client.so

